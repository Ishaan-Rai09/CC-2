# App Settings
APP_NAME="Smart Notes API"
APP_VERSION="1.0.0"
DEBUG=True

# Security (Change in production!)
SECRET_KEY="supersecretkey-change-in-production-min32chars"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database
DATABASE_URL="sqlite:///./smart_notes.db"

# AWS S3 Settings
AWS_ACCESS_KEY_ID="your_access_key_here"
AWS_SECRET_ACCESS_KEY="your_secret_key_here"
AWS_SESSION_TOKEN="your_session_token_here_if_using_aws_academy"
AWS_REGION="us-east-1"
AWS_BUCKET_NAME="smart-notes-files"

# CORS
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]
